generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Business {
  id         String       @id @default(cuid())
  name       String
  type       String
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  clients    Client[]
  bills      Bill[]
  quotations Quotation[]
  expenses   Expense[]
  payments   Payment[]
}

model Client {
  id          String     @id @default(cuid())
  businessId  String
  name        String
  email       String?
  phone       String
  address     String?
  company     String?
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  business    Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bills       Bill[]
  quotations  Quotation[]
  payments    Payment[]
}

model Bill {
  id          String     @id @default(cuid())
  businessId  String
  clientId    String
  billNumber  String
  date        DateTime
  dueDate     DateTime
  subtotal    Float
  tax         Float      @default(0)
  discount    Float      @default(0)
  total       Float
  paidAmount  Float      @default(0)
  status      String     @default("unpaid")
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  business    Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client      Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items       BillItem[]
  payments    Payment[]
}

model BillItem {
  id          String @id @default(cuid())
  billId      String
  description String
  quantity    Float
  rate        Float
  amount      Float
  bill        Bill   @relation(fields: [billId], references: [id], onDelete: Cascade)
}

model Quotation {
  id              String          @id @default(cuid())
  businessId      String
  clientId        String
  quotationNumber String
  date            DateTime
  validUntil      DateTime
  subtotal        Float
  tax             Float           @default(0)
  discount        Float           @default(0)
  total           Float
  status          String          @default("draft")
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  business        Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client          Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items           QuotationItem[]
}

model QuotationItem {
  id           String    @id @default(cuid())
  quotationId  String
  description  String
  quantity     Float
  rate         Float
  amount       Float
  quotation    Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model Expense {
  id            String   @id @default(cuid())
  businessId    String
  category      String
  description   String
  amount        Float
  date          DateTime
  paymentMethod String?
  receipt       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String   @id @default(cuid())
  businessId    String
  clientId      String
  billId        String?
  amount        Float
  date          DateTime
  paymentMethod String
  receiptNumber String
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  bill          Bill?    @relation(fields: [billId], references: [id], onDelete: SetNull)
}
